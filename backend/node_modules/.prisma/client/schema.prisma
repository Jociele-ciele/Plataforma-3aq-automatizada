generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATE
  RECRUITER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role
  githubLogin  String?  @map("github_login")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  candidateProfile CandidateProfile?
  jobsCreated      Job[]             @relation("RecruiterJobs")

  @@map("users")
}

model CandidateProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  phone              String?
  bio                String?
  cvFilePath         String?   @map("cv_file_path")
  cvMimeType         String?   @map("cv_mime_type")
  cvExtractedText    String?   @map("cv_extracted_text") @db.Text
  technicalScore     Float?    @map("technical_score")
  fitScore           Float?    @map("fit_score")
  lastAnalysisAt     DateTime? @map("last_analysis_at")
  githubAnalysisJson Json?     @map("github_analysis_json")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("candidate_profiles")
}

model Job {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  stack       String[]
  criteria    Json?
  isOpen      Boolean  @default(true) @map("is_open")
  recruiterId String   @map("recruiter_id")
  createdAt   DateTime @default(now()) @map("created_at")

  recruiter    User          @relation("RecruiterJobs", fields: [recruiterId], references: [id])
  applications Application[]
  challenges   Challenge[]

  @@map("jobs")
}

model Application {
  id          String   @id @default(uuid())
  jobId       String   @map("job_id")
  candidateId String   @map("candidate_id")
  status      String   @default("SUBMITTED")
  appliedAt   DateTime @default(now()) @map("applied_at")

  job         Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([jobId, candidateId])
  @@map("applications")
}

model Challenge {
  id          String @id @default(uuid())
  jobId       String @map("job_id")
  title       String
  description String @db.Text
  language    String @default("javascript")
  starterCode String @map("starter_code") @db.Text
  testCases   Json   @map("test_cases")
  timeLimitMs Int    @default(5000) @map("time_limit_ms")

  job         Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("challenges")
}

model Submission {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  challengeId   String   @map("challenge_id")
  code          String   @db.Text
  passedTests   Int      @map("passed_tests")
  totalTests    Int      @map("total_tests")
  feedback      String   @db.Text
  scorePercent  Float    @map("score_percent")
  createdAt     DateTime @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  challenge   Challenge   @relation(fields: [challengeId], references: [id])

  @@map("submissions")
}
