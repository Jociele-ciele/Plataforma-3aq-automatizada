generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATO
  RECRUTADOR
}

model users {
  id            String   @id @default(uuid())
  email         String   @unique
  senha_hash    String
  nome          String
  role          Role
  github_login  String?
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  perfis_candidatos perfis_candidatos?
  vagas             vagas[]            @relation("VagasRecrutador")

  @@map("users")
}

model perfis_candidatos {
  id                   String    @id @default(uuid())
  usuario_id           String    @unique
  telefone             String?
  bio                  String?
  caminho_cv           String?
  tipo_mime_cv         String?
  texto_extraido_cv    String?   @db.Text
  nota_tecnica         Float?
  nota_compatibilidade Float?
  ultima_analise_em    DateTime?
  analise_github_json  Json?

  usuario      users          @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  candidaturas candidaturas[]

  @@map("perfis_candidatos")
}

model vagas {
  id            String   @id @default(uuid())
  titulo        String
  descricao     String   @db.Text
  tecnologias   String[]
  criterios     Json?
  aberta        Boolean  @default(true)
  recrutador_id String
  criado_em     DateTime @default(now())

  recrutador   users          @relation("VagasRecrutador", fields: [recrutador_id], references: [id])
  candidaturas candidaturas[]
  desafios     desafios[]

  @@map("vagas")
}

model candidaturas {
  id             String   @id @default(uuid())
  vaga_id        String
  candidato_id   String
  status         String   @default("ENVIADO")
  candidatura_em DateTime @default(now())

  vaga       vagas             @relation(fields: [vaga_id], references: [id], onDelete: Cascade)
  candidato  perfis_candidatos @relation(fields: [candidato_id], references: [id], onDelete: Cascade)
  submissoes submissoes[]

  @@unique([vaga_id, candidato_id])
  @@map("candidaturas")
}

model desafios {
  id              String @id @default(uuid())
  vaga_id         String
  titulo          String
  descricao       String @db.Text
  linguagem       String @default("javascript")
  codigo_inicial  String @db.Text
  casos_teste     Json
  limite_tempo_ms Int    @default(5000)

  vaga       vagas        @relation(fields: [vaga_id], references: [id], onDelete: Cascade)
  submissoes submissoes[]

  @@map("desafios")
}

model submissoes {
  id               String   @id @default(uuid())
  candidatura_id   String
  desafio_id       String
  codigo           String   @db.Text
  testes_aprovados Int
  total_testes     Int
  feedback         String   @db.Text
  percentual_nota  Float
  criado_em        DateTime @default(now())

  candidatura candidaturas @relation(fields: [candidatura_id], references: [id], onDelete: Cascade)
  desafio     desafios     @relation(fields: [desafio_id], references: [id])

  @@map("submissoes")
}
