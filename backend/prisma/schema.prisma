// Schema do banco — 3aq Talent
// Cada entidade tem comentários em português explicando o que guarda.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATO
  RECRUTADOR
}

enum JobStatus {
  ABERTA
  ENCERRADA
  RASCUNHO
}

enum ApplicationStatus {
  INSCRITO
  EM_ANALISE
  APROVADO
  REPROVADO
}

enum ChallengeType {
  MULTIPLA_ESCOLHA
  CODIGO_JS
}

// ----------- Usuário (Candidato ou Recrutador) -----------
model User {
  id            String   @id @default(cuid())
  nome          String
  email         String   @unique
  senha         String
  role          Role     @default(CANDIDATO)
  github        String?
  bio           String?
  avatar        String?
  aceitouLGPD   Boolean  @default(false)
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // relações
  resumes         Resume[]
  applications    Application[]
  submissions     Submission[]
  githubAnalysis  GithubAnalysis?
  jobsCriadas     Job[]            @relation("RecrutadorJobs")
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
}

// ----------- Token de refresh (para manter login seguro) -----------
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ----------- Vaga -----------
model Job {
  id           String      @id @default(cuid())
  titulo       String
  descricao    String
  tecnologias  String[]
  senioridade  String      @default("PLENO")
  status       JobStatus   @default(ABERTA)
  recrutadorId String
  recrutador   User        @relation("RecrutadorJobs", fields: [recrutadorId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  challenges   Challenge[]
  applications Application[]
}

// ----------- Currículo -----------
model Resume {
  id            String   @id @default(cuid())
  candidatoId   String
  candidato     User     @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
  arquivo       String   // caminho do PDF salvo (criptografado)
  nomeArquivo   String
  textoExtraido String   @db.Text
  createdAt     DateTime @default(now())
}

// ----------- Inscrição em uma vaga -----------
model Application {
  id            String             @id @default(cuid())
  candidatoId   String
  candidato     User               @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
  vagaId        String
  vaga          Job                @relation(fields: [vagaId], references: [id], onDelete: Cascade)
  status        ApplicationStatus  @default(INSCRITO)
  notaFinal     Float              @default(0)
  scoreCurriculo Float             @default(0)
  scoreGithub    Float             @default(0)
  scoreDesafios  Float             @default(0)
  resumoIA       String?           @db.Text
  feedback       String?           @db.Text
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  submissions   Submission[]

  @@unique([candidatoId, vagaId])
}

// ----------- Desafio (questão ou código JS) -----------
model Challenge {
  id           String         @id @default(cuid())
  vagaId       String
  vaga         Job            @relation(fields: [vagaId], references: [id], onDelete: Cascade)
  tipo         ChallengeType
  enunciado    String         @db.Text
  // se for múltipla escolha:
  alternativas Json?          // [{id:'a', texto:'...'}, ...]
  respostaCorreta String?
  // se for código JS:
  exemplos     Json?          // [{entrada:[1,2], saida:3}]
  casosTeste   Json?          // [{entrada:[2,3], saidaEsperada:5}, ...]
  peso         Int            @default(1)
  createdAt    DateTime       @default(now())

  submissions  Submission[]
}

// ----------- Resposta do candidato a um desafio -----------
model Submission {
  id            String      @id @default(cuid())
  challengeId   String
  challenge     Challenge   @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  candidatoId   String
  candidato     User        @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
  applicationId String?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  codigo        String?     @db.Text   // código submetido (se for JS)
  resposta      String?     // alternativa marcada (se for múltipla escolha)
  nota          Float       @default(0)
  detalhes      Json?       // resultado de cada caso de teste
  createdAt     DateTime    @default(now())
}

// ----------- Análise do GitHub -----------
model GithubAnalysis {
  id              String   @id @default(cuid())
  candidatoId     String   @unique
  candidato       User     @relation(fields: [candidatoId], references: [id], onDelete: Cascade)
  username        String
  score           Float
  repositorios    Int
  estrelas        Int
  seguidores      Int
  tecnologias     String[]
  ultimaAtividade DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ----------- Logs de auditoria (LGPD) -----------
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  acao      String
  entidade  String?
  detalhes  Json?
  ip        String?
  createdAt DateTime @default(now())
}
